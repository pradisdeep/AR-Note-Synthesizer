__pycache__/
*.pyc
*.pyo
.env
.venv/
venv/
.streamlit/secrets.toml
.DS_Store
*.egg-info/
.pytest_cache/

# Physician POC: only let *_redacted.csv and derived feature tables
# (synthesized/accounts/clusters) be committed. Raw extracts must never reach git.
physician_poc/data/*
!physician_poc/data/*_redacted.csv
!physician_poc/data/synthesized.csv
!physician_poc/data/accounts.csv
!physician_poc/data/clusters.csv
!physician_poc/data/.gitkeep
